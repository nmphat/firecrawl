# Firecrawl -- self-hosted web scraping API
# Copy to .env and fill in your values.

# API server port
PORT=3092

# Bind address
HOST=0.0.0.0

# Disable DB auth for local-only deployments
# Options: "false" | "true" | 0 | 1
# WARNING: Zod may crash on plain false -- use 0 if container fails
USE_DB_AUTHENTICATION=false

# Bull queue auth key
# Generate: openssl rand -hex 16
BULL_AUTH_KEY=your-key

# SearXNG endpoint for web search (optional)
SEARXNG_ENDPOINT=http://searxng:8080
